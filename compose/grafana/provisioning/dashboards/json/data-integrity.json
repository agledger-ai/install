{
  "annotations": { "list": [] },
  "description": "AGLedger silent-data-loss surveillance. Every panel here surfaces a failure mode that would otherwise be invisible in logs alone — non-zero rate is signal, investigate.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
