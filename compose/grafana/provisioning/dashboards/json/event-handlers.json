{
  "annotations": { "list": [] },
  "description": "Event-handler silent-drop surveillance. Each panel here surfaces a fire-and-forget path that swallows errors at runtime — a non-zero rate means data is being dropped on the floor without raising. Investigate any color change.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "At-a-glance summary across every silent-drop counter on this dashboard. If this is non-zero, something on the chain is being dropped silently right now.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(agledger_cascade_cancel_enqueue_failures_total[24h])) + sum(increase(agledger_webhook_enqueue_failures_total[24h])) + sum(increase(agledger_cascading_verification_enqueue_failures_total[24h])) + sum(increase(agledger_phase2_enqueue_failures_total[24h])) + sum(increase(agledger_reputation_update_failures_total[24h])) + sum(increase(agledger_siem_mapper_failures_total[24h])) + sum(increase(agledger_auth_audit_persist_failures_total[24h])) + sum(increase(agledger_federation_outbound_enqueue_failed_total[24h])) + sum(increase(agledger_siem_http_batches_dropped_total[24h])) + sum(increase(agledger_siem_file_lines_dropped_total[24h]))",
          "legendFormat": "drops in last 24h",
          "refId": "A"
        }
      ],
      "title": "Silent drops — total events dropped in last 24h",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Cascade-cancel enqueue failures — when a parent record terminalizes, children are supposed to fan out and cancel. A failure here orphans a child that may keep executing. Highest operational stakes on this dashboard.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (scope) (rate(agledger_cascade_cancel_enqueue_failures_total[5m]))",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ],
      "title": "Cascade-cancel enqueue failures (drops/sec) — agledger_cascade_cancel_enqueue_failures_total",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Webhook dispatch-time enqueue failures. Distinct from `agledger_webhooks_failed_total` which is the *delivery* failure counter — this is the one-step-earlier failure where the webhook never made it onto the queue at all. Customer never sees it; we never retry it.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.001 }
            ]
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["max", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (stage) (rate(agledger_webhook_enqueue_failures_total[5m]))",
          "legendFormat": "{{stage}}",
          "refId": "A"
        }
      ],
      "title": "Webhook enqueue failures (drops/sec) — agledger_webhook_enqueue_failures_total",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
